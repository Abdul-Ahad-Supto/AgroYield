# .env file for Amoy Testnet

# Required for deployment
PRIVATE_KEY=your_private_key_here
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# Alternative RPC URLs for Amoy (backup)
# AMOY_RPC_URL=https://polygon-amoy.blockpi.network/v1/rpc/public
# AMOY_RPC_URL=https://polygon-amoy-bor-rpc.publicnode.com

# Optional - for gas reporting
REPORT_GAS=true
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# Frontend configuration
REACT_APP_NETWORK_ID=80002
REACT_APP_NETWORK_NAME=amoy
REACT_APP_RPC_URL=https://rpc-amoy.polygon.technology
REACT_APP_EXPLORER_URL=https://amoy.polygonscan.com

# Contract addresses (filled after deployment)
REACT_APP_PROJECT_FACTORY=
REACT_APP_INVESTMENT_MANAGER=
REACT_APP_IDENTITY_REGISTRY=
REACT_APP_ORACLE_INTEGRATION=
REACT_APP_YIELD_DISTRIBUTOR=
REACT_APP_GOVERNANCE_MODULE=
REACT_APP_USDC_ADDRESS=0x41E94Eb019C0762f9Bfcf9Fb1E58725BfB0e7582